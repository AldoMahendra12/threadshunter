NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-admin-key

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-claude-api-key

# Meta Developer API (Threads + Instagram Graph API)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-custom-meta-webhook-verify-token

# Stripe Payments & Subscriptions
STRIPE_SECRET_KEY=your-stripe-secret-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_STARTER_PRICE_ID=price_starter_id
STRIPE_PRO_PRICE_ID=price_pro_id
STRIPE_SCALE_PRICE_ID=price_scale_id

# App Security & Scheduler Keys
INTERNAL_API_SECRET=your-strong-internal-api-secret-key
CRON_SECRET=your-strong-vercel-cron-secret-key

# Resend Email Delivery
RESEND_API_KEY=your-resend-api-key

# Deployment & Routing
NEXT_PUBLIC_APP_URL=http://localhost:3000
